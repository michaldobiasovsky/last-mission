<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox spacing="8" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lab.LevelDetailsController">
    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>
    <children>
        <Label text="Level details" style="-fx-font-weight: bold; -fx-font-size: 16;" />
        <Label fx:id="nameLabel" text="Name: -" wrapText="true" />
        <Label fx:id="totalLabel" text="Total: -" />
        <Label fx:id="neededLabel" text="Needed: -" />
        <Label fx:id="entryLabel" text="Entry: -" />
        <Label fx:id="abilitiesLabel" text="Abilities: -" wrapText="true" />
        <Label fx:id="bestTimeLabel" text="Best time: -" />
        <HBox spacing="8" style="-fx-padding: 10 0 0 0;">
            <children>
                <Button fx:id="playButton" text="Play" onAction="#onPlay" disable="true" />
                <Button text="Back" onAction="#onBack" />
            </children>
        </HBox>
    </children>
</VBox>
