<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="600.0" prefWidth="800.0" spacing="20.0" style="-fx-background-color: #2a5298;" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lab.MainMenuController">
    <padding>
        <Insets bottom="40" left="40" right="40" top="40" />
    </padding>

    <Button fx:id="startButton" mnemonicParsing="false" onAction="#startGame" prefWidth="200" text="Start">
        <font>
            <Font size="24" />
        </font>
    </Button>
   <Button fx:id="levelsButton" mnemonicParsing="false" onAction="#showLevels" prefWidth="200" text="Levels">
      <font>
         <Font size="18" />
      </font>
   </Button>

    <Button fx:id="loginButton" mnemonicParsing="false" onAction="#login" prefWidth="200" text="Login">
        <font>
            <Font size="18" />
        </font>
    </Button>
   <Button fx:id="exitButton" mnemonicParsing="false" onAction="#exitApp" prefWidth="200" text="Exit">
      <font>
         <Font size="18" />
      </font>
   </Button>
</VBox>
