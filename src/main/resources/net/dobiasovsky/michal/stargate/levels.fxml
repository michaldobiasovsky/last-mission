<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefWidth="1025.0" prefHeight="769.0"
            styleClass="levels-root"
            xmlns="http://javafx.com/javafx/23"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="net.dobiasovsky.michal.stargate.LevelsController">

    <top>
        <HBox spacing="12.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="16.0" right="16.0" bottom="16.0" left="16.0"/>
            </padding>
            <Button text="Back" onAction="#onBack"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Level Selection" style="-fx-font-size: 22px; -fx-font-weight: bold;">
            </Label>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>
    </top>

    <left>
        <VBox spacing="10.0" prefWidth="360.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="16.0" right="16.0" bottom="16.0" left="16.0"/>
            </padding>
            <Label text="Levels" style="-fx-font-size: 18px; -fx-font-weight: bold;">
            </Label>
            <ListView fx:id="levelList" VBox.vgrow="ALWAYS"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="10.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="16.0" right="16.0" bottom="16.0" left="16.0"/>
            </padding>
            <Label text="Details" style="-fx-font-size: 18px; -fx-font-weight: bold;">
            </Label>

            <VBox spacing="6.0">
                <Label fx:id="nameLabel" text="Name: \u2013"/>
                <Label fx:id="totalLabel" text="Total: \u2013"/>
                <Label fx:id="neededLabel" text="Needed: \u2013"/>
                <Label fx:id="abilitiesLabel" text="Abilities: \u2013"/>
                <Label fx:id="bestTimeLabel" text="Best time: \u2013"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <Button fx:id="playButton" text="Play" onAction="#onPlay" disable="true"
                    prefHeight="48.0" maxWidth="1.7976931348623157E308"/>
        </VBox>
    </center>

</BorderPane>
